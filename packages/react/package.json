{
  "name": "@lisse/react",
  "version": "0.2.0",
  "description": "React hook and component for smooth-cornered (squircle) elements",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lisse/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceThings/Lisse",
    "directory": "packages/react"
  },
  "keywords": [
    "squircle",
    "smooth-corners",
    "react",
    "hook",
    "component",
    "border-radius",
    "clip-path"
  ],
  "homepage": "https://github.com/JaceThings/Lisse#readme",
  "bugs": "https://github.com/JaceThings/Lisse/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
