{
  "name": "@lisse/svelte",
  "version": "0.1.0",
  "description": "Svelte action for smooth-cornered (squircle) elements",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lisse/core": "workspace:*"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceThings/smooth-corners",
    "directory": "packages/svelte"
  },
  "peerDependencies": {
    "svelte": ">=3.0.0"
  },
  "keywords": ["squircle", "smooth-corners", "svelte", "action", "border-radius", "clip-path"],
  "homepage": "https://github.com/JaceThings/smooth-corners#readme",
  "bugs": "https://github.com/JaceThings/smooth-corners/issues"
}
