{
  "name": "@smooth-corners/svelte",
  "version": "0.1.0",
  "description": "Svelte action for smooth-cornered (squircle) elements",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@smooth-corners/core": "workspace:*"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceThings/smooth-corners",
    "directory": "packages/svelte"
  },
  "keywords": ["squircle", "smooth-corners", "svelte", "action"]
}
