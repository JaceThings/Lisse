{
  "name": "@lisse/core",
  "version": "0.3.1",
  "description": "Framework-agnostic squircle path generation based on Figma's smoothing algorithm",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./path": {
      "import": {
        "types": "./dist/path.d.ts",
        "default": "./dist/path.js"
      },
      "require": {
        "types": "./dist/path.d.cts",
        "default": "./dist/path.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceThings/Lisse",
    "directory": "packages/core"
  },
  "keywords": [
    "squircle",
    "smooth-corners",
    "border-radius",
    "figma",
    "svg-path",
    "clip-path",
    "superellipse"
  ],
  "homepage": "https://github.com/JaceThings/Lisse#readme",
  "bugs": "https://github.com/JaceThings/Lisse/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
